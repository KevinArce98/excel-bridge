{
  "name": "excel-bridge",
  "version": "1.0.5",
  "description": "A lightweight, modular Excel manipulation library based on micro-packages",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "prepublishOnly": "npm run test:run && npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "fast-xml-parser": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KevinArce98/excel-bridge.git"
  },
  "author": "Kevin Arias",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KevinArce98/excel-bridge/issues"
  },
  "homepage": "https://github.com/KevinArce98/excel-bridge#readme"
}
